# Ambiente de TESTE (desenvolvimento)
STRIPE_SECRET_KEY=sk_test_51_COLE_AQUI_SUA_CHAVE_DE_TESTE_______________________

# Ambiente de PRODUГ‡ГѓO (quando publicar)
