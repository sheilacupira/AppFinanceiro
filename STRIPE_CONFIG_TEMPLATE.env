STRIPE_WEBHOOK_SECRET=whsec__COLE_AQUI_O_WEBHOOK_SECRET________________________

# ====================================
# 3. PRICE IDs - PLANO PRO
# ====================================
# Produto: AppFinanceiro Pro
# Obtenha em: https://dashboard.stripe.com/products

# PreГ§o Mensal: R$ 29,90 BRL
STRIPE_PRICE_PRO_MONTHLY=price_1_COLE_AQUI_O_PRICE_ID_MENSAL_PRO_______________

# PreГ§o Anual: R$ 299,00 BRL (economize 17%)
STRIPE_PRICE_PRO_YEARLY=price_1_COLE_AQUI_O_PRICE_ID_ANUAL_PRO________________

# ====================================
# 4. PRICE IDs - PLANO ENTERPRISE
# ====================================
# Produto: AppFinanceiro Enterprise

# PreГ§o Mensal: R$ 99,90 BRL
