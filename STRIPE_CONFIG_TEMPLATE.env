# PreГ§o Anual: R$ 999,00 BRL (economize 17%)
STRIPE_PRICE_ENTERPRISE_YEARLY=price_1_COLE_AQUI_O_PRICE_ID_ANUAL_ENTERPRISE__

# ====================================
# 5. URL DE RETORNO (Portal do Cliente)
# ====================================
# URL para onde o usuГЎrio retorna apГіs gerenciar assinatura no Stripe

BILLING_PORTAL_RETURN_URL=http://localhost:8080/config

# Em produГ§ГЈo, use:
# BILLING_PORTAL_RETURN_URL=https://seu-dominio.com/config

